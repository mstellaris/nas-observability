    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-Interface Throughput",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ifHCInOctets[5m]) * 8",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{ifName}} in"
        },
        {
          "refId": "B",
          "expr": "rate(ifHCOutOctets[5m]) * 8",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{ifName}} out"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
