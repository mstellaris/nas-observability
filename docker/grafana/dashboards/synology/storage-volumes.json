{
  "annotations": {"list": []},
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "bargauge",
      "title": "Per-Volume Usage",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (raidTotalSize{raidName=~\"Volume.*\"} - raidFreeSize{raidName=~\"Volume.*\"}) / raidTotalSize{raidName=~\"Volume.*\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": "{{raidName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Per-Volume Free Space",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "raidFreeSize{raidName=~\"Volume.*\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": "{{raidName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 100000000000},
              {"color": "green", "value": 500000000000}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Disk Health",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "diskHealthStatus",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": "{{diskName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {"text": "Normal", "color": "green", "index": 0},
                "2": {"text": "Warning", "color": "yellow", "index": 1},
                "3": {"text": "Critical", "color": "red", "index": 2},
                "4": {"text": "Failing", "color": "red", "index": 3}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 3}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Volume IOPS (reads + writes)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "label_replace(rate(storageIOReads[5m]), \"diskLabel\", \"Disk $1\", \"storageIODevice\", \"sata(.+)\")",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{diskLabel}} reads/s"
        },
        {
          "refId": "B",
          "expr": "label_replace(rate(storageIOWrites[5m]), \"diskLabel\", \"Disk $1\", \"storageIODevice\", \"sata(.+)\")",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{diskLabel}} writes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Storage Pool Status",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "raidStatus",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": "{{raidName}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {"text": "Normal", "color": "green", "index": 0},
                "2": {"text": "Repairing", "color": "yellow", "index": 1},
                "3": {"text": "Migrating", "color": "yellow", "index": 2},
                "4": {"text": "Expanding", "color": "yellow", "index": 3},
                "5": {"text": "Deleting", "color": "yellow", "index": 4},
                "11": {"text": "Crashed", "color": "red", "index": 5}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 2},
              {"color": "red", "value": 11}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value_and_name",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["synology", "storage"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "NAS Observability — Storage & Volumes",
  "uid": "storage-volumes",
  "version": 1,
  "weekStart": ""
}
