    {
      "id": 5,
      "type": "stat",
      "title": "Ingestion: Low Confidence (total)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 10},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "ingestion_jobs_total{state=\"low_confidence\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Ingestion Job Rate by State",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (state) (rate(ingestion_jobs_total[5m]))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Ingestion Duration p50 / p95 / p99 (by parser_type)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, parser_type) (rate(ingestion_duration_seconds_bucket[5m])))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "p50 {{parser_type}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, parser_type) (rate(ingestion_duration_seconds_bucket[5m])))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "p95 {{parser_type}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, parser_type) (rate(ingestion_duration_seconds_bucket[5m])))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "p99 {{parser_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "Awaiting ingestion runs — Mneme F002 ships the worker code that observes this histogram. Until then, the metric is registered but emits no series.",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 8,
      "type": "heatmap",
      "title": "Parser Confidence Distribution",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (le) (increase(parser_confidence_bucket[5m]))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "noValue": "Awaiting ingestion runs — parser_confidence histogram is registered but emits no series until Mneme F002's worker observes it.",
          "custom": {
            "scaleDistribution": {"type": "linear"},
            "hideFrom": {"tooltip": false, "viz": false, "legend": false}
          }
        },
        "overrides": []
      },
      "options": {
        "calculate": false,
        "yAxis": {"axisPlacement": "left", "reverse": false, "unit": "short"},
        "rowsFrame": {"layout": "auto"},
        "color": {
          "mode": "scheme",
          "fill": "dark-orange",
          "scheme": "Oranges",
          "exponent": 0.5,
          "min": 0,
          "steps": 64,
          "reverse": false
        },
        "cellGap": 1,
        "filterValues": {"le": 1e-9},
        "tooltip": {"show": true, "yHistogram": false},
        "legend": {"show": true},
        "exemplars": {"color": "rgba(255,0,255,0.7)"}
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Node.js Worker Process: Memory (RSS + Heap)",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 22},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{job=\"mneme-worker\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "RSS"
        },
        {
          "refId": "B",
          "expr": "nodejs_heap_size_total_bytes{job=\"mneme-worker\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "heap (total)"
        },
        {
          "refId": "C",
          "expr": "nodejs_heap_size_used_bytes{job=\"mneme-worker\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "heap (used)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    }
  ],
