      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"mneme-frontend\"} | logfmt | context_source=\"react_boundary\"",
          "queryType": "range"
        }
      ],
      "fieldConfig": {"defaults": {"noValue": "No React error-boundary errors in range (healthy)"}, "overrides": []},
      "options": {
