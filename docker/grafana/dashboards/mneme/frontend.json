    {
      "id": 2,
      "type": "stat",
      "title": "Total Exceptions (range)",
      "description": "Echo-dedup: excludes Faro captureConsole's echo, which is kind=exception (SAME kind as the real error) with value prefixed 'console.error:'. Do NOT replace `!= \"console.error:\"` with a kind or detected_level filter — the echo shares the kind, and detected_level is a Loki heuristic, not a contract. The 'console.error:' value-prefix is the only deterministic separator (verified 0 false-matches over 7d). See specs/005 spec.md D2.",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"mneme-frontend\"} |= \"kind=exception\" != \"console.error:\" [$__range]))",
          "queryType": "instant",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "noValue": "0 — no frontend exceptions in range (healthy)",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 25}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 3,
