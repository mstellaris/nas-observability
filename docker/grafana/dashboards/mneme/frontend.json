      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"mneme-frontend\"} |= \"kind=exception\" != \"console.error:\" [$__auto]))",
          "queryType": "range",
          "legendFormat": "exceptions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "fixed", "fixedColor": "red"},
