        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": false},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top Exception Messages (deduped)",
      "description": "Echo-dedup via the 'console.error:' value-prefix exclusion before `| logfmt` (see Total Exceptions panel). NOT a kind/detected_level filter. spec.md D2.",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "topk(10, sum by (value) (count_over_time({service_name=\"mneme-frontend\"} |= \"kind=exception\" != \"console.error:\" | logfmt [$__range])))",
          "queryType": "instant",
          "legendFormat": "",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}, "inspect": false},
          "noValue": "No frontend exceptions in range (healthy)"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.width", "value": 90}, {"id": "displayName", "value": "count"}]}
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{"displayName": "count", "desc": true}]
      },
      "transformations": [
        {"id": "labelsToFields", "options": {"mode": "columns"}},
        {"id": "organize", "options": {"excludeByName": {"Time": true}, "renameByName": {"value": "exception"}}}
      ]
    },
    {
