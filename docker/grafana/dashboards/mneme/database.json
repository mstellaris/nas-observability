{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Connections",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_numbackends{datname!~\"template.*|postgres\"})",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connection Pool Saturation",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_numbackends) / on() group_left() pg_settings_max_connections * 100",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 80}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Mneme Database Size",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_database_size_bytes{datname=\"mneme\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Active Connections (over time, by database)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_database_numbackends{datname!~\"template.*\"}",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Transaction Rate (commits + rollbacks)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_commit{datname=\"mneme\"}[5m]))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{datname}} commits/s"
        },
        {
          "refId": "B",
          "expr": "sum by (datname) (rate(pg_stat_database_xact_rollback{datname=\"mneme\"}[5m]))",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "{{datname}} rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"], "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cache Hit Ratio (Mneme database)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "pg_stat_database_blks_hit{datname=\"mneme\"} / (pg_stat_database_blks_hit{datname=\"mneme\"} + pg_stat_database_blks_read{datname=\"mneme\"}) * 100",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "legendFormat": "cache hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 2,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 90},
              {"color": "green", "value": 99}
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false,
            "showPoints": "never",
            "thresholdsStyle": {"mode": "line"}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": ["lastNotNull"], "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Slow Queries (top 10 by call count)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, pg_stat_statements_calls)",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "instant": true,
          "format": "table",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "pg_stat_statements extension not installed — see docs/mneme-setup.md §Troubleshooting to enable. Slow-query observability requires the extension; without it this panel intentionally renders empty rather than erroring.",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "blue", "value": null}]
          },
          "custom": {"align": "left", "cellOptions": {"type": "auto"}}
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {"show": false, "reducer": ["sum"], "countRows": false, "fields": ""}
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true, "instance": true, "job": true, "server": true},
            "indexByName": {},
            "renameByName": {"Value": "calls"}
          }
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mneme", "database"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Mneme — Database",
  "uid": "mneme-database",
  "version": 1,
  "weekStart": ""
}
