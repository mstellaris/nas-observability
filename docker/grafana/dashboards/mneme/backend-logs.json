      "type": "logs",
      "title": "API Log Stream",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"mneme-api-1\"}",
          "queryType": "range"
