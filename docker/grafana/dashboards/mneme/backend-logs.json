    {
      "id": 31,
      "type": "logs",
      "title": "Postgres Log Stream (raw)",
      "description": "Postgres is plain text: `<ts> UTC [<pid>] <SEVERITY>:  <msg>`. Raw stream — NO | json (D7/FR-63).",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 42},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{service_name=\"mneme-postgres-1\"}",
          "queryType": "range"
        }
      ],
      "fieldConfig": {"defaults": {"noValue": "No mneme-postgres-1 logs in range"}, "overrides": []},
      "options": {
        "showTime": true, "showLabels": false, "showCommonLabels": false,
        "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true,
        "dedupStrategy": "none", "sortOrder": "Descending"
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Postgres Severity (ERROR/FATAL/PANIC/WARNING)",
      "description": "Position-anchored regex `\\] (ERROR|FATAL|PANIC|WARNING):` — anchored on the [pid] bracket + trailing colon so it cannot match these words inside a message body. Includes PANIC (a naive ERROR|FATAL would miss panics). NEVER | json on postgres (D7).",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 42},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum(count_over_time({service_name=\"mneme-postgres-1\"} |~ `\\] (ERROR|FATAL|PANIC|WARNING):` [$__auto]))",
          "queryType": "range",
          "legendFormat": "error/fatal/panic/warning"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "noValue": "0 — no postgres error/fatal/panic/warning in range (healthy)",
          "color": {"mode": "fixed", "fixedColor": "red"},
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "spanNulls": false, "showPoints": "never"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": [], "showLegend": false},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    }
