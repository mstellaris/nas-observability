# Grafana admin credentials.
# Copy this file to .env (which is gitignored) and change GRAFANA_ADMIN_PASSWORD
# to a real value BEFORE the first deploy. The committed default is a tripwire,
# not a usable credential.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# SNMP community string for the Synology NAS (Feature 002) is NOT stored here.
# It lives at /volume1/docker/observability/snmp_exporter/.community on the NAS
# (mode 600, owned 1026:100), where scripts/init-nas-paths.sh reads it to render
# snmp.yml from the committed template. Setup flow documented in
# docs/snmp-setup.md §Step 3.

# POSTGRES_METRICS_PASSWORD (Feature 003) is set in Portainer's stack environment,
# NOT in this file. It's the password for Mneme's `mneme_metrics` Postgres user
# (read-only, pg_monitor role) that postgres_exporter uses to scrape Mneme's DB.
# Generated and provisioned per docs/mneme-setup.md §Step 3.
