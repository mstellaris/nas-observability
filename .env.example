# Grafana admin credentials.
# Copy this file to .env (which is gitignored) and change GRAFANA_ADMIN_PASSWORD
# to a real value BEFORE the first deploy. The committed default is a tripwire,
# not a usable credential.

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# SNMP community string for the Synology NAS (Feature 002) is NOT stored here.
# It lives at /volume1/docker/observability/snmp_exporter/.community on the NAS
# (mode 600, owned 1026:100), where scripts/init-nas-paths.sh reads it to render
# snmp.yml from the committed template. Setup flow documented in
# docs/snmp-setup.md §Step 3.

# POSTGRES_METRICS_PASSWORD (Feature 003) is set in Portainer's stack environment,
# NOT in this file. It's the password for Mneme's `mneme_metrics` Postgres user
# (read-only, pg_monitor role) that postgres_exporter uses to scrape Mneme's DB.
# Generated and provisioned per docs/mneme-setup.md §Step 3.

# Faro RUM receiver (Feature 004) — set these in the LOGS/RUM stack's Portainer
# environment (docker-compose.logs.yml), not the metrics stack. Alloy reads them
# via sys.env at runtime; they are never baked into config.alloy.
#
# FARO_API_KEY gates the Faro receiver — browsers send it as the `x-api-key`
# header, and it is the SOLE access layer (no reverse proxy in front; receiver
# binds host interfaces directly — see docs/logs-setup.md §Receiver posture).
# Generate a real value with: openssl rand -base64 32. The committed value is a
# tripwire, not usable.
FARO_API_KEY=changeme
#
# FARO_ALLOWED_ORIGINS is the comma-separated CORS allow-list — the EXACT
# origins browsers load Mneme from. NEVER use `*`. Two paths on this NAS:
# LAN (Tailscale off) and Tailscale. Adjust to your own host/tailnet names.
FARO_ALLOWED_ORIGINS=http://192.168.0.8:8080,http://ds224plus.tailda1ab8.ts.net:8080
